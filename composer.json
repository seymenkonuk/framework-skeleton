{
    "name": "seymenkonuk/framework-skeleton",
    "description": "seymenkonuk/framework kullanılarak hazırlanmış başlangıç projesi. Yeni uygulamalar için hızlı kurulum sağlar.",
    "type": "project",
    "license": "MIT",
    "authors": [
        {
            "name": "Recep Seymen Konuk",
            "email": "konukrecepseymen@gmail.com"
        }
    ],
    "autoload": {
        "psr-4": {
            "ProjectName\\App\\": "app/",
            "ProjectName\\Config\\": "config/",
            "ProjectName\\Routes\\": "routes/"
        }
    },
    "require": {
        "seymenkonuk/framework": "^1.0"
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "require-dev": {
        "phpunit/phpunit": "^11.5",
        "phpstan/phpstan": "^2.0"
    }
}